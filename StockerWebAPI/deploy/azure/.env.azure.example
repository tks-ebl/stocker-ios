ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_HTTP_PORTS=8080
CONNECTIONSTRINGS__DEFAULT=Host=<postgres-flexible-server>.postgres.database.azure.com;Port=5432;Database=stocker;Username=<db-user>;Password=<db-password>;Ssl Mode=Require;Trust Server Certificate=false
JWT__ISSUER=StockerWebAPI
JWT__AUDIENCE=StockerClients
JWT__SIGNINGKEY=<set-a-long-random-secret-in-key-vault-or-container-app-secret>
SEED__ENABLEDEMOSEED=false

